{{- /* Template package metadata for generated Python SDKs. */ -}}
[project]
name = {{ printf "%q" .ProjectName }}
version = "0.0.0" {{- /* The real version is set on release. */}}
description = {{ printf "%q" .PackageDescription }}
authors = [
  { name = "Vadim Romanov", email = "vadim@centraluniversity.dev" }
]
maintainers = [
  { name = "CU Devs Collective" }
]
license = { text = "MIT" }
requires-python = "{{ .PythonVersion }}"
dependencies = [
  "httpx{{ .HttpxVersion }}",
  "attrs{{ .AttrsVersion }}",
  "python-dateutil{{ .PythonDateutilVersion }}",
]

[project.urls]
Homepage = "https://github.com/cu-devs-collective/open-cu-services-sdk"
Repository = "https://github.com/cu-devs-collective/open-cu-services-sdk"
Issues = "https://github.com/cu-devs-collective/open-cu-services-sdk/issues"

[tool.uv.build-backend]
module-name = {{ printf "%q" .PackageImportName }}
module-root = ""

[build-system]
requires = ["uv_build{{ .UvVersion }}"]
build-backend = "uv_build"

[tool.ruff]
line-length = 80

[tool.ruff.lint]
select = ["E", "F", "I", "UP"]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"
