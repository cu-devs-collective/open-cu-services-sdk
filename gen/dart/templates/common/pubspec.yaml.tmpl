{{- /* Template pubspec.yaml for generated Dart SDKs. */ -}}
name: {{ .PackageName }}
version: {{ or .PackageVersion "0.0.0" }} {{- /* The real version is set on release. */}}
publish_to: none
description: {{ .PackageDescription }}
homepage: https://github.com/cu-devs-collective/open-cu-services-sdk
repository: https://github.com/cu-devs-collective/open-cu-services-sdk
issue_tracker: https://github.com/cu-devs-collective/open-cu-services-sdk/issues

environment:
  sdk: {{ printf "%q" .DartSdkVersion }}

dependencies:
  archive: {{ printf "%q" .ArchiveVersion }}
  chopper: {{ printf "%q" .ChopperVersion }}
  collection: {{ printf "%q" .CollectionVersion }}
  http: {{ printf "%q" .HttpVersion }}
  json_annotation: {{ printf "%q" .JsonAnnotationVersion }}
  sodium: {{ printf "%q" .SodiumVersion }}

dev_dependencies:
  swagger_dart_code_generator: {{ printf "%q" .SwaggerDartCodeGeneratorVersion }}
  build_runner: {{ printf "%q" .BuildRunnerVersion }}
  chopper_generator: {{ printf "%q" .ChopperGeneratorVersion }}
  json_serializable: {{ printf "%q" .JsonSerializableVersion }}
