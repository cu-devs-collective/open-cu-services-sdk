{{- /* Template for setting package description and constants. */ -}}
// Code generated by gen-sdk-golang, DO NOT EDIT.
{{ if .PackageDescription }}
/* {{ .PackageDescription }} */{{ end }}
package {{ .Package }}

import (
	"runtime/debug"
	"sync"
)

const (
	DefaultBaseURL   = {{ printf "%q" .BaseURL }}
	DefaultUserAgent = {{ printf "%q" .UserAgent }}
)

var (
	versionOnce sync.Once
	version     = "unknown"
)

func Version() string {
	versionOnce.Do(func() {
		buildInfo, ok := debug.ReadBuildInfo()
		if !ok {
			return
		}

		const modPath = "github.com/cu-devs-collective/open-cu-services-sdk/golang/{{ .Package }}"
		for _, dep := range buildInfo.Deps {
			if dep.Path != modPath {
				continue
			}
			if dep.Replace != nil && dep.Replace.Version != "" {
				version = dep.Replace.Version
				return
			}
			if dep.Version != "" {
				version = dep.Version
				return
			}
			return
		}
	})

	return version
}
